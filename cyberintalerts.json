                    "description": "Comma-separated severity levels to filter (leave empty for all severities)",
                    "data_type": "string",
                    "required": false,
                    "order": 1,
                    "value_list": [
                        "",
                        "low",
                        "medium",
                        "high",
                        "very_high"
                    ]
                },
                "Statuses": {
                    "description": "Comma-separated statuses to filter (leave empty for all statuses)",
                    "data_type": "string",
                    "required": false,
                    "order": 2,
                    "value_list": [
                        "",
                        "open",
